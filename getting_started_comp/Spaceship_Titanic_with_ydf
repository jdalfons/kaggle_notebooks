    "from sklearn.preprocessing import OrdinalEncoder\n",
    "\n",
    "def feature_engineering(df_input):\n",
    "    \"\"\"\n",
    "    Matematicas transformations\n",
    "    \"\"\"\n",
    "    # Copy from original DF\n",
    "    df = df_input.copy()\n",
    "    \n",
    "    # 1. Calculate the expresions\n",
    "    gastos_basicos = ['ShoppingMall', 'Spa', 'VRDeck']\n",
    "    gastos_lujo = ['RoomService', 'FoodCourt',]\n",
    "\n",
    "    # null vals to 0\n",
    "    df['lux_Expenses'] = df[gastos_lujo].fillna(0).sum(axis=1)\n",
    "    df['basic_Expenses'] = df[gastos_basicos].fillna(0).sum(axis=1)\n",
    "    \n",
    "    # 2. Bools to int (1 y 0)\n",
    "    df['CryoSleep'] = df['CryoSleep'].fillna(False).astype(int)\n",
    "    # df['VIP'] = df['VIP'].fillna(False).astype(int)\n",
    "    \n",
    "    # 3. Cabin separation\n",
    "    df[['Deck', 'Num', 'Side']] = df['Cabin'].str.split('/', expand=True)\n",
    "    \n",
    "    # 4. Filter to necessary columns\n",
    "    columnas_a_mantener = [\n",
    "        'PassengerId','HomePlanet', 'Destination', 'CryoSleep', 'VIP', \n",
    "        'basic_Expenses', 'lux_Expenses', 'Deck', 'Side'\n",
    "    ]\n",
    "    \n",
    "    if 'Transported' in df.columns:\n",
    "        columnas_a_mantener.append('Transported')\n",
    "        \n",
    "    return df[columnas_a_mantener]\n"
   ]
  },
